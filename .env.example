# --- Bedrock (gerar questões) ---
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1
# Modelo ATIVO (não "Legada") — copie o "Inference profile ID" do Bedrock → Model catalog
# Amazon (sem formulário Anthropic):
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0
# Alternativas se habilitadas na sua conta:
# BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0
# BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-20250514-v1:0

# --- OCR Textract (PDF escaneado) — precisa IAM Access Key (AKIA...) ---
# A chave Bedrock sozinha NÃO serve para Textract/S3.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Bucket na MESMA região do AWS_REGION (criar no console S3)
S3_BUCKET=meu-bucket-gera-questoes
S3_PREFIX=ocr-uploads/

# Chunking / limites
CHUNK_SIZE_CHARS=12000
CHUNK_OVERLAP_CHARS=1500
MAX_CHUNKS_PER_REQUEST=30
MAX_PDF_UPLOAD_MB=500
MIN_CHARS_PER_PAGE_NATIVE=30
TEXTRACT_POLL_SECONDS=10
OCR_JOBS_DIR=data/ocr_jobs
